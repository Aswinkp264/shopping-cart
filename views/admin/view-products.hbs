<section>
  <div class="container">
    <div class="row">
      <div class="d-flex justify-content-end mb-3">
        <a href="/admin/add-products" class="btn btn-success">Add</a>
      </div>
    </div>

    <table class="table">
      <thead>
        <tr>
          <th scope="col">No</th>
          <th scope="col">Title</th>
          <th scope="col">Category</th>
          <th scope="col">Description</th>
          <th scope="col">Image</th>
        </tr>
      </thead>
      <tbody>
        {{#each Products}}

          <tr>
            <th scope="row">1</th>
            <td>{{this.name}}</td>
            <td>{{this.category}}</td>
            <td>{{this.description}}</td>
            <td><img
                style="width: 50px;height: 50px;"
                src="{{this.image}}"
                alt="products"
              /></td>

          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</section>
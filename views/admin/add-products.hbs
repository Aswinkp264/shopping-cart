<div class="premium-bg">

  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-lg-5 col-md-7">

        <div class="premium-card">

          <h3 class="text-center fw-bold mb-4 text-white">
            ✨ Add New Product
          </h3>

          <form
            action="/admin/add-products"
            method="POST"
            enctype="multipart/form-data"
            onsubmit="return validateForm();"
          >

            <!-- Product Name -->
            <div class="mb-3">
              <label class="form-label text-light">Product Name</label>
              <input type="text" id="name" name="name"
                class="form-control premium-input">
              <small class="text-danger" id="nameError"></small>
            </div>

            <!-- Category -->
            <div class="mb-3">
              <label class="form-label text-light">Category</label>
              <input type="text" id="category" name="category"
                class="form-control premium-input">
              <small class="text-danger" id="categoryError"></small>
            </div>

            <!-- Description -->
            <div class="mb-3">
              <label class="form-label text-light">Description</label>
              <textarea id="description" name="description"
                class="form-control premium-input"
                style="height:100px"></textarea>
              <small class="text-danger" id="descriptionError"></small>
            </div>

            <!-- Price -->
            <div class="mb-3">
              <label class="form-label text-light">Price (₹)</label>
              <input type="number" id="price" name="price"
                class="form-control premium-input">
              <small class="text-danger" id="priceError"></small>
            </div>

            <!-- Image Upload -->
            <div class="mb-3">
              <label class="form-label text-light">Upload Image</label>
              <input type="file"
                     id="image"
                     name="image"
                     class="form-control premium-input"
                     accept="image/*"
                     onchange="previewImage(event)">
              <small class="text-danger" id="imageError"></small>
            </div>

            <!-- Image Preview -->
            <div class="text-center mb-4">
              <img id="imagePreview"
                   class="img-fluid rounded-4 shadow d-none"
                   style="max-height: 180px;">
            </div>

            <!-- Button -->
            <div class="d-grid">
              <button class="btn premium-btn">
                🚀 Add Product
              </button>
            </div>

          </form>

        </div>

      </div>
    </div>
  </div>

</div>

<style>
/* Background */
.premium-bg {
  min-height: 100vh;
  background: linear-gradient(135deg, #1e1e2f, #2b2b45);
  display: flex;
  align-items: center;
}

/* Card */
.premium-card {
  backdrop-filter: blur(12px);
  background: rgba(255, 255, 255, 0.08);
  padding: 40px;
  border-radius: 20px;
  box-shadow: 0 15px 40px rgba(0,0,0,0.4);
  border: 1px solid rgba(255,255,255,0.1);
}

/* Inputs */
.premium-input {
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  color: white;
  border-radius: 12px;
  padding: 12px;
}

.premium-input::placeholder {
  color: #ddd;
}

.premium-input:focus {
  background: rgba(255,255,255,0.15);
  border-color: #ffc107;
  box-shadow: 0 0 12px rgba(255,193,7,0.4);
  color: white;
}

/* Button */
.premium-btn {
  background: linear-gradient(135deg, #ff9800, #ff5722);
  border: none;
  padding: 12px;
  border-radius: 30px;
  font-weight: bold;
  color: white;
  transition: all 0.3s ease;
}

.premium-btn:hover {
  transform: translateY(-3px);
  box-shadow: 0 10px 25px rgba(0,0,0,0.4);
}

/* Animation */
.premium-card {
  animation: fadeInUp 0.5s ease;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(25px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
</style>

<script>
function previewImage(e) {
  const img = document.getElementById("imagePreview");
  img.src = URL.createObjectURL(e.target.files[0]);
  img.classList.remove("d-none");
}

function validateForm() {
  let ok = true;

  ["nameError","categoryError","descriptionError","priceError","imageError"]
    .forEach(id => document.getElementById(id).innerText = "");

  if (!name.value.trim()) {
    nameError.innerText = "Required";
    ok = false;
  }

  if (!category.value.trim()) {
    categoryError.innerText = "Required";
    ok = false;
  }

  if (!description.value.trim()) {
    descriptionError.innerText = "Required";
    ok = false;
  }

  if (!price.value || price.value <= 0) {
    priceError.innerText = "Invalid price";
    ok = false;
  }

  if (!image.files.length) {
    imageError.innerText = "Image required";
    ok = false;
  }

  return ok;
}
</script>

<header>
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css"
    rel="stylesheet"
  />
  <script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
  ></script>

  <nav class="navbar navbar-expand-lg navbar-dark shadow-sm custom-navbar">
    <div class="container">

      <!-- Brand -->
      <a class="navbar-brand fw-bold" href="/">
        🛒 ShopCart
      </a>

      <!-- Toggle -->
      <button
        class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#navbarContent"
      >
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbarContent">
        <ul class="navbar-nav ms-auto align-items-center">

          <!-- Products -->
          <li class="nav-item mx-2">
            <a class="nav-link nav-custom" href="/">Products</a>
          </li>

          <!-- Cart -->
          <li class="nav-item mx-3 position-relative">
            <a class="nav-link nav-custom position-relative" href="/cart">
              <i class="bi bi-cart3 fs-5"></i>
              {{#if cartCount}}
                <span class="badge bg-danger rounded-pill cart-badge">
                  {{cartCount}}
                </span>
              {{/if}}
            </a>
          </li>

          <!-- Orders -->
          {{#if user}}

            <li class="nav-item mx-2">
              <a class="nav-link nav-custom" href="/orders">Orders</a>
            </li>
          {{/if}}
          <!-- Account Dropdown -->
          <li class="nav-item dropdown mx-2">
            <a
              class="nav-link dropdown-toggle d-flex align-items-center nav-custom"
              href="#"
              role="button"
              data-bs-toggle="dropdown"
            >

              <div class="avatar-circle me-2">
                {{#if user}}
                  {{user.name.[0]}}
                {{else}}
                  <i class="bi bi-person"></i>
                {{/if}}
              </div>

              {{#if user}}
                {{user.name}}
              {{else}}
                Account
              {{/if}}
            </a>

            <ul
              class="dropdown-menu dropdown-menu-end modern-dropdown shadow border-0"
            >

              {{#if user}}

                <li class="dropdown-header text-center">
                  <strong>{{user.name}}</strong><br />
                  <small class="text-muted">Welcome back 👋</small>
                </li>

                <li><hr class="dropdown-divider" /></li>

                <li>
                  <a class="dropdown-item modern-item" href="/profile">
                    <i class="bi bi-person me-2"></i>Profile
                  </a>
                </li>

                <li>
                  <a
                    class="dropdown-item modern-item text-danger"
                    href="/logout"
                  >
                    <i class="bi bi-box-arrow-right me-2"></i>Logout
                  </a>
                </li>

              {{else}}

                <li>
                  <a class="dropdown-item modern-item" href="/login">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Login
                  </a>
                </li>

                <li>
                  <a class="dropdown-item modern-item" href="/signup">
                    <i class="bi bi-person-plus me-2"></i>Signup
                  </a>
                </li>

              {{/if}}

            </ul>
          </li>

        </ul>
      </div>
    </div>
  </nav>
</header>

<style>
  .custom-navbar {
    background: linear-gradient(135deg, #1e1e2f, #2b2b45);
  }

  .nav-custom {
    color: white !important;
    font-weight: 500;
  }

  .nav-custom:hover {
    color: #ffc107 !important;
  }

  .avatar-circle {
    width: 34px;
    height: 34px;
    background: linear-gradient(135deg, #ff9800, #ff5722);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
  }

  .cart-badge {
    font-size: 11px;
    position: absolute;
    top: -6px;
    right: -10px;
  }

  .modern-dropdown {
    width: 230px;
    border-radius: 12px;
    padding: 8px 0;
    animation: fadeIn 0.2s ease-in-out;
  }

  .modern-item {
    padding: 10px 18px;
    transition: all 0.2s ease;
  }

  .modern-item:hover {
    background: #f8f9fa;
    padding-left: 22px;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>